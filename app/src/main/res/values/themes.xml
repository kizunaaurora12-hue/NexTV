<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base theme - dark untuk TV -->
    <style name="Theme.NexTV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:colorBackground">@color/bg_deep</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/bg_deep</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
    </style>

    <!-- Theme tanpa ActionBar -->
    <style name="Theme.NexTV.NoActionBar" parent="Theme.NexTV">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Theme Player - fullscreen tanpa status bar -->
    <style name="Theme.NexTV.Player" parent="Theme.NexTV.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:keepScreenOn">true</item>
    </style>

    <!-- Style untuk Category Chip -->
    <style name="Widget.NexTV.CategoryChip">
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- Style untuk Channel Card -->
    <style name="Widget.NexTV.ChannelCard">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

</resources>
