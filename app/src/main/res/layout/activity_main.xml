<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout utama NexTV — 2 kolom: Sidebar kiri + Konten kanan
    Sesuai desain SymphogearTV
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_deep">

    <!-- ══════════════════════════════════════════
         SIDEBAR KIRI (lebar tetap 280dp)
    ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_sidebar"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp">

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NexTV"
            android:textColor="@color/accent"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TELEVISION"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="24dp" />

        <!-- Status live streaming -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_panel"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="28dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/shape_live_dot"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live Streaming"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AKTIF"
                    android:textColor="@color/status_online"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Label KATEGORI -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KATEGORI"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Daftar kategori (scroll vertikal) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:fadeScrollbars="true">

            <LinearLayout
                android:id="@+id/category_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Label KUALITAS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KUALITAS"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Filter kualitas -->
        <LinearLayout
            android:id="@+id/quality_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         KONTEN KANAN
    ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/bg_deep">

        <!-- ── TOPBAR ── -->
        <LinearLayout
            android:id="@+id/topbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@color/bg_deep"
            android:elevation="4dp">

            <!-- Breadcrumb kategori aktif -->
            <View
                android:layout_width="3dp"
                android:layout_height="20dp"
                android:background="@color/accent"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tv_active_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[TV] SEMUA CHANNEL"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginEnd="16dp" />

            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_search_bar"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/text_muted"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Cari channel..."
                    android:textColorHint="@color/text_dim"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- LIVE badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_live_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginEnd="8dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/shape_live_dot"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE"
                    android:textColor="#FFFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <!-- Search icon btn -->
            <ImageView
                android:id="@+id/btn_search_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_search"
                android:tint="@color/text_muted"
                android:background="@drawable/bg_icon_btn"
                android:padding="9dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <!-- Refresh -->
            <ImageView
                android:id="@+id/btn_refresh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_refresh"
                android:tint="@color/text_muted"
                android:background="@drawable/bg_icon_btn"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <!-- Force Refresh -->
            <ImageView
                android:id="@+id/btn_force_refresh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_refresh"
                android:tint="@color/accent"
                android:background="@drawable/bg_icon_btn"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <!-- Settings / Exit -->
            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_settings"
                android:tint="@color/text_muted"
                android:background="@drawable/bg_icon_btn"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ── INFO CARD (jumlah channel, kualitas, DRM, custom) ── -->
        <LinearLayout
            android:id="@+id/layout_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_panel"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp">

            <!-- App title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="18dp"
                    android:background="@color/accent"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NexTV"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- PREMIUM badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PREMIUM"
                    android:textColor="@color/accent"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:background="@drawable/bg_badge_accent"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Channel count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/bg_card">

                    <TextView
                        android:id="@+id/tv_total_channel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHANNEL"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <View android:layout_width="4dp" android:layout_height="1dp" />

                <!-- Kualitas -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/bg_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HD"
                        android:textColor="@color/accent"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KUALITAS"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <View android:layout_width="4dp" android:layout_height="1dp" />

                <!-- DRM -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/bg_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DRM"
                        android:textColor="@color/accent"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SECURE"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <View android:layout_width="4dp" android:layout_height="1dp" />

                <!-- Custom -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/bg_card">

                    <TextView
                        android:id="@+id/tv_custom_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CUSTOM"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── HEADER SECTION (nama kategori + count badge) ── -->
        <LinearLayout
            android:id="@+id/layout_section_header"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="4dp">

            <View
                android:layout_width="3dp"
                android:layout_height="16dp"
                android:background="@color/accent"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tv_section_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Semua"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Count badge -->
            <TextView
                android:id="@+id/tv_channel_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/bg_deep"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_accent"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginEnd="6dp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_right"
                android:tint="@color/text_muted" />
        </LinearLayout>

        <!-- ── CONTENT ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Channel Grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_channels"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp"
                android:clipToPadding="false"
                android:scrollbars="vertical" />

            <!-- Loading -->
            <LinearLayout
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminateTint="@color/accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Memuat channel…"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- Error -->
            <LinearLayout
                android:id="@+id/tv_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡"
                    android:textSize="48sp" />

                <TextView
                    android:id="@+id/tv_error_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gagal memuat channel"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/btn_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coba Lagi"
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:background="@drawable/bg_btn_outline"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginTop="16dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </FrameLayout>
    </LinearLayout>

</LinearLayout>
