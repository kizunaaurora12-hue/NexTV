<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sidebar_item_root"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="6dp"
    android:paddingEnd="8dp"
    android:layout_marginBottom="2dp"
    android:focusable="true"
    android:clickable="true">

    <!-- Selected accent bar (kiri) -->
    <View
        android:id="@+id/sidebar_accent"
        android:layout_width="3dp"
        android:layout_height="18dp"
        android:background="@color/accent"
        android:layout_marginEnd="10dp"
        android:visibility="invisible" />

    <!-- Category icon text -->
    <TextView
        android:id="@+id/sidebar_icon"
        android:layout_width="32dp"
        android:layout_height="22dp"
        android:gravity="center"
        android:textColor="#50FFD700"
        android:textSize="8sp"
        android:textStyle="bold"
        android:background="@color/bg_hover"
        android:layout_marginEnd="10dp" />

    <!-- Category name -->
    <TextView
        android:id="@+id/sidebar_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#E0B0BAD0"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Count badge -->
    <TextView
        android:id="@+id/sidebar_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#55FFD700"
        android:textSize="10sp"
        android:background="@color/bg_hover"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp" />

</LinearLayout>
