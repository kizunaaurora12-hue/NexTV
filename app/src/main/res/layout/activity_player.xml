<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:keepScreenOn="true">

    <!--
        PlayerView dengan controller TERINTEGRASI (custom_control).
        Kontrol muncul/hilang otomatis saat tap — sama seperti SymphogearTV.
        controllerShowTimeoutMs=4000 → auto-hide setelah 4 detik.
    -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:keepScreenOn="true"
        app:controller_layout_id="@layout/player_custom_control"
        app:show_buffering="when_playing"
        app:use_controller="true"
        app:hide_on_touch="true"
        app:keep_content_on_player_reset="true" />

    <!-- ── PANEL KANAN: Daftar Channel (di luar PlayerView) ──────── -->
    <LinearLayout
        android:id="@+id/panel_channel_list"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="#EE050810"
        android:elevation="10dp"
        android:visibility="gone">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:background="@color/bg_panel">

            <View
                android:layout_width="3dp"
                android:layout_height="18dp"
                android:background="@color/accent"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CHANNEL"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/btn_close_panel"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="✕"
                android:textColor="@color/text_muted"
                android:textSize="16sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Search -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@color/bg_card">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_search"
                android:tint="@color/text_muted"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_panel_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Cari channel…"
                android:textColorHint="@color/text_dim"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:inputType="text"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Channel list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_panel_channels"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical" />
    </LinearLayout>

    <!-- ── POPUP RESOLUSI ──────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/popup_resolution"
        android:layout_width="170dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="68dp"
        android:layout_marginEnd="180dp"
        android:orientation="vertical"
        android:background="@color/bg_panel"
        android:elevation="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESOLUSI"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="6dp" />

        <TextView android:id="@+id/res_auto"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:gravity="center_vertical" android:paddingStart="14dp"
            android:text="⚡  Auto (Default)"
            android:textColor="@color/accent" android:textSize="13sp"
            android:clickable="true" android:focusable="true" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

        <TextView android:id="@+id/res_1080"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:gravity="center_vertical" android:paddingStart="14dp"
            android:text="🔹  1080p"
            android:textColor="@color/text_primary" android:textSize="13sp"
            android:clickable="true" android:focusable="true" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

        <TextView android:id="@+id/res_720"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:gravity="center_vertical" android:paddingStart="14dp"
            android:text="🔹  720p"
            android:textColor="@color/text_primary" android:textSize="13sp"
            android:clickable="true" android:focusable="true" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

        <TextView android:id="@+id/res_480"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:gravity="center_vertical" android:paddingStart="14dp"
            android:text="🔹  480p"
            android:textColor="@color/text_primary" android:textSize="13sp"
            android:clickable="true" android:focusable="true" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

        <TextView android:id="@+id/res_360"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:gravity="center_vertical" android:paddingStart="14dp"
            android:text="🔹  360p"
            android:textColor="@color/text_primary" android:textSize="13sp"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <!-- ── POPUP UKURAN LAYAR ──────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/popup_screen_mode"
        android:layout_width="190dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="68dp"
        android:layout_marginEnd="130dp"
        android:orientation="vertical"
        android:background="@color/bg_panel"
        android:elevation="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UKURAN LAYAR"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="6dp" />

        <TextView android:id="@+id/screen_fit"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:gravity="center_vertical" android:paddingStart="14dp"
            android:text="▣  Fit (Default)"
            android:textColor="@color/accent" android:textSize="13sp"
            android:clickable="true" android:focusable="true" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

        <TextView android:id="@+id/screen_fixed_width"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:gravity="center_vertical" android:paddingStart="14dp"
            android:text="↔  Fixed Width"
            android:textColor="@color/text_primary" android:textSize="13sp"
            android:clickable="true" android:focusable="true" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

        <TextView android:id="@+id/screen_fixed_height"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:gravity="center_vertical" android:paddingStart="14dp"
            android:text="↕  Fixed Height"
            android:textColor="@color/text_primary" android:textSize="13sp"
            android:clickable="true" android:focusable="true" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

        <TextView android:id="@+id/screen_fill"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:gravity="center_vertical" android:paddingStart="14dp"
            android:text="⬛  Fill"
            android:textColor="@color/text_primary" android:textSize="13sp"
            android:clickable="true" android:focusable="true" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

        <TextView android:id="@+id/screen_zoom"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:gravity="center_vertical" android:paddingStart="14dp"
            android:text="🔍  Zoom"
            android:textColor="@color/text_primary" android:textSize="13sp"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <!-- Notifikasi pindah channel -->
    <TextView
        android:id="@+id/tv_channel_switch_notif"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="72dp"
        android:background="@color/bg_status_overlay"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text=""
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:elevation="12dp" />

    <!-- Buffering / Status overlay -->
    <LinearLayout
        android:id="@+id/overlay_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_status_overlay"
        android:padding="20dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progress_buffering"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:indeterminateTint="@color/accent" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Memuat…"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</FrameLayout>
